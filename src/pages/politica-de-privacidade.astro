---
/**
 * Página: Política de Privacidade
 *
 * O que faz:
 * Renderiza a página legal e burocrática essencial para o compliance da empresa (LGPD).
 * Ela injeta o "miolo" textual massivo no centro da página através do componente `PrivacyPolicySection`.
 *
 * Onde é usado:
 * É renderizada na rota oficial `/politica-de-privacidade`. Tipicamente lincada apenas no rodapé (Footer).
 */

import Layout from "../layouts/Layout.astro";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

import PrivacyPolicySection from "../components/PrivacyPolicySection.astro";
---

<Layout>
  <Header />

  <main>
    <PrivacyPolicySection />
  </main>

  <Footer />
</Layout>
