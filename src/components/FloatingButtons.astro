---
/**
 * Componente: FloatingButtons.astro
 *
 * O que faz:
 * Este componente renderiza os botões flutuantes que ficam fixos na tela (geralmente no canto inferior direito).
 * Ele inclui:
 * - Um botão de contato rápido que redireciona para o WhatsApp.
 * - Um botão de "Voltar ao topo" que rola a página de volta para cima suavemente.
 *
 * Onde é usado:
 * Geralmente é inserido no layout base/principal do site (ex: BaseLayout.astro)
 * para estar presente em todas as páginas, facilitando a interação e a navegação do usuário.
 */

// Importa o componente de Imagem otimizado do framework Astro
import { Image } from "astro:assets";
// Importa o ícone SVG do WhatsApp para o botão
import whatsappIcon from "../assets/images/whatsapp.svg";
---

<div id="floating-actions" class="floating-wrapper hidden">
  <a
    href={`https://wa.me/${import.meta.env.PUBLIC_WHATSAPP_NUMBER}?text=${encodeURIComponent("Olá! Gostaria de agendar uma coleta de óleo.")}`}
    target="_blank"
    rel="noopener noreferrer"
    class="fab btn-whatsapp"
    aria-label="Falar no WhatsApp"
  >
    <Image src={whatsappIcon} alt="WhatsApp" />
  </a>

  <button id="btn-back-to-top" class="fab btn-top" aria-label="Voltar ao topo">
    <!-- Ícone SVG inline representando uma seta direcional (chevron up) -->
    <svg
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M18 15l-6-6-6 6"></path>
    </svg>
  </button>
</div>

<style>
  @import "../styles/components-styles/floating_buttons.css";
</style>

<script src="../scripts/floating_buttons.js"></script>
