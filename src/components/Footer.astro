---
/**
 * Componente: Footer.astro
 *
 * O que faz:
 * Este componente renderiza o rodapé (footer) do site.
 * Ele engloba:
 * - Um formulário de contato rápido ("Pronto para reciclar?").
 * - Links diretos de contato (Telefone, E-mail) e redes sociais (Instagram, WhatsApp).
 * - Menus de navegação rápida (Início, Como Funciona, FAQ, Privacidade, etc.).
 * - O logotipo da empresa.
 *
 * Onde é usado:
 * Geralmente é importado no layout principal (ex: BaseLayout.astro) para ser exibido
 * na parte inferior de absolutamente todas as páginas do site.
 */

// Importações do componente de imagem nativo do Astro e dos assets necessários (SVGs)
import { Image } from "astro:assets";
import instagramIcon from "../assets/images/instagram_icon.svg";
import whatsappIcon from "../assets/images/whatsapp_icon.svg";
import logoV3 from "../assets/images/logo_v3.svg";
---

<!-- 
  Elemento semântico de rodapé. 
  Possui o id="contato" que é alvo de âncoras para quando o usuário clicar em "Contato" no menu.
-->
<footer id="contato" class="footer-section">
  <div class="footer-container">
    <!-- Cabeçalho de CTA (Call to Action) convidando o usuário a agir -->
    <div class="footer-cta-header">
      <p class="section-title">
        <span class="block text-brand-gray">PRONTO PARA</span>
        <span class="block text-brand-green">RECICLAR?</span>
      </p>
    </div>

    <!-- Wrapper que engloba o formulário de contato e os estados de envio (loading, success, error) -->
    <div class="contact-wrapper">
      <!-- Container inicial contendo os campos do formulário visíveis -->
      <div id="form-container">
        <!-- 
          O form tem dados como data-validate="true" para que o script validacao.js saiba que ele
          precisa de verificação antes de tentar o envio.
          data-submit-type="mock" indica que fará uma simulação temporária, não um post real no momento.
        -->
        <form
          id="contact-form"
          class="contact-form"
          data-validate="true"
          data-submit-type="mock"
        >
          <!-- 
            Campo 'Honeypot' (isca).
            Fica escondido visualmente pelo CSS. Se preenchido, indica que é um bot de spam, 
            pois um humano não o veria.
          -->
          <input
            type="text"
            name="website"
            class="honey-field"
            tabindex="-1"
            autocomplete="off"
          />

          <div class="inputs-grid">
            <!-- Grupo Input: Nome do usuário -->
            <div class="input-group">
              <input
                type="text"
                id="footer-name"
                name="name"
                placeholder="Seu Nome"
                aria-label="Seu Nome"
                required
                class="contact-input"
              />
              <span class="error-text">Preencha este campo</span>
            </div>

            <!-- Grupo Input: Endereço de e-mail -->
            <div class="input-group">
              <input
                type="email"
                id="footer-email"
                name="email"
                placeholder="seu@email.com"
                aria-label="Seu endereço de e-mail"
                required
                class="contact-input"
              />
              <span class="error-text">Formato de e-mail inválido</span>
            </div>

            <!-- Grupo Input: Telefone/WhatsApp com máscara -->
            <div class="input-group">
              <input
                type="tel"
                id="footer-phone"
                name="contact"
                placeholder="Seu Contato (WhatsApp)"
                aria-label="Seu número de WhatsApp"
                required
                class="contact-input phone-mask"
              />
              <span class="error-text">Telefone inválido</span>
            </div>
          </div>

          <!-- Botão de submit do formulário -->
          <button type="submit" id="submit-btn" class="btn-submit">
            <span class="btn-text">Enviar dados</span>
          </button>
        </form>

        <!-- Texto explicativo complementar ao formulário -->
        <p class="contact-note">
          Insira suas informações para que possamos entrar em contato com você.
        </p>
      </div>

      <!-- Feedback UI: Estado de carregamento, oculto por padrão (.hidden) -->
      <div id="loading-state" class="state-message hidden">
        <div class="spinner"></div>
        <p>Enviando...</p>
      </div>

      <!-- Feedback UI: Estado de sucesso, exibido via JS se tudo der certo -->
      <div id="success-state" class="state-message hidden">
        <div class="success-icon">✓</div>
        <p class="small-text">Em breve entraremos em contato.</p>
      </div>

      <!-- Feedback UI: Estado de erro geral (ex: falha de internet) -->
      <div id="error-message" class="error-message hidden">
        <p>
          Ocorreu um erro de conexão. Por favor, tente nos chamar diretamente
          pelo WhatsApp.
        </p>
      </div>
    </div>

    <!-- Grid que distribui as 3 colunas de links adicionais no rodapé -->
    <div class="footer-links-grid">
      <!-- Coluna 1: Informações de Contato Direto -->
      <div class="footer-link-col">
        <h4 class="link-title">Contatos</h4>
        <ul class="link-list">
          <li>
            <span class="link-item" style="cursor: default;"
              >Telefone: (51) 9631-9035</span
            >
          </li>
          <li>
            <a href="mailto:coletapapaoleo@gmail.com" class="link-item"
              >E-mail: coletapapaoleo@gmail.com</a
            >
          </li>
        </ul>

        <!-- Container de botões com as mídias sociais -->
        <div class="social-icons">
          <!-- Botão Instagram -->
          <a
            href="https://www.instagram.com/papaoleocoleta/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="social-icon"
          >
            <Image src={instagramIcon} alt="Instagram" loading="lazy" />
          </a>

          <!-- Botão WhatsApp com URL gerada por variável de ambiente -->
          <a
            href={`https://wa.me/${import.meta.env.PUBLIC_WHATSAPP_NUMBER}?text=${encodeURIComponent("Olá! Gostaria de agendar uma coleta de óleo.")}`}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="WhatsApp"
            class="social-icon"
          >
            <Image src={whatsappIcon} alt="WhatsApp" loading="lazy" />
          </a>
        </div>
      </div>

      <!-- Coluna 2: Navegação Principal do Site (Links internos âncoras e rotas) -->
      <nav class="footer-link-col" aria-labelledby="title-nav">
        <h4 id="title-nav" class="link-title">Navegação</h4>
        <ul class="link-list">
          <li><a href="/" class="link-item">Início</a></li>
          <li><a href="/#o-que-fazemos" class="link-item">Como Funciona</a></li>
          <li>
            <a href="/#quem-atendemos" class="link-item">Quem atendemos</a>
          </li>
          <li>
            <a href="/#cobertura" class="link-item">Onde atendemos</a>
          </li>
        </ul>
      </nav>

      <!-- Coluna 3: Documentação e Informações Gerais -->
      <nav class="footer-link-col" aria-labelledby="title-info">
        <h4 id="title-info" class="link-title">Informações gerais</h4>
        <ul class="link-list">
          <li><a href="/faq" class="link-item">FAQ</a></li>
          <li>
            <a href="/politica-de-privacidade" class="link-item"
              >Política de Privacidade</a
            >
          </li>
        </ul>
      </nav>
    </div>

    <!-- Divisão final do rodapé contendo apenas a logomarca da empresa -->
    <div class="footer-bottom">
      <div class="footer-logo">
        <Image
          src={logoV3}
          alt="Logo Papa Óleo - Coleta de Óleo de Cozinha"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</footer>

<!-- 
  Bloco de Estilo exclusivo do componente.
  Importa o CSS externo com as propriedades que moldam a aparência de tudo que vimos acima.
-->
<style>
  @import "../styles/components-styles/footer.css";
</style>

<!-- 
  Script Global de Validação:
  Contém as regras de máscara, validação de campos vazios/e-mail/telefone e 
  também o envio/mock do formulário. 'defer' faz o script rodar após o HTML carregar.
-->
<script src="../scripts/form_validate.js"></script>
