---
import { Image } from "astro:assets";
import instagramIcon from "../assets/images/instagram_icon.svg";
import whatsappIcon from "../assets/images/whatsapp_icon.svg";
import logoV3 from "../assets/images/logo_v3.svg";
---

<footer id="contato" class="footer-section">
  <div class="footer-container">
    <div class="footer-cta-header">
      <p class="section-title">
        <span class="block text-brand-gray">PRONTO PARA</span>
        <span class="block text-brand-green">RECICLAR?</span>
      </p>
    </div>

    <div class="contact-wrapper">
      <div id="form-container">
        <form id="contact-form" class="contact-form" data-validate="true" data-submit-type="mock">
          <input
            type="text"
            name="website"
            class="honey-field"
            tabindex="-1"
            autocomplete="off"
          />
          <div class="inputs-grid">
            <div class="input-group">
              <input
                type="text"
                id="footer-name"
                name="name"
                placeholder="Seu Nome"
                aria-label="Seu Nome"
                required
                class="contact-input"
              />
              <span class="error-text">Preencha este campo</span>
            </div>
            <div class="input-group">
              <input
                type="email"
                id="footer-email"
                name="email"
                placeholder="seu@email.com"
                aria-label="Seu endereço de e-mail"
                required
                class="contact-input"
              />
              <span class="error-text">Formato de e-mail inválido</span>
            </div>
            <div class="input-group">
              <input
                type="tel"
                id="footer-phone"
                name="contact"
                placeholder="Seu Contato (WhatsApp)"
                aria-label="Seu número de WhatsApp"
                required
                class="contact-input phone-mask"
              />
              <span class="error-text">Telefone inválido</span>
            </div>
          </div>

          <button type="submit" id="submit-btn" class="btn-submit">
            <span class="btn-text">Enviar dados</span>
          </button>
        </form>
        <p class="contact-note">
          Insira suas informações para que possamos entrar em contato com você.
        </p>
      </div>

      <div id="loading-state" class="state-message hidden">
        <div class="spinner"></div>
        <p>Enviando...</p>
      </div>

      <div id="success-state" class="state-message hidden">
        <div class="success-icon">✓</div>
        <p class="small-text">Em breve entraremos em contato.</p>
      </div>

      <div id="error-message" class="error-message hidden">
        <p>
          Ocorreu um erro de conexão. Por favor, tente nos chamar diretamente
          pelo WhatsApp.
        </p>
      </div>
    </div>

    <div class="footer-links-grid">
      <div class="footer-link-col">
        <h4 class="link-title">Contatos</h4>
        <ul class="link-list">
          <li>
            <span class="link-item" style="cursor: default;"
              >Telefone: (51) 9631-9035</span
            >
          </li>
          <li>
            <a href="mailto:coletapapaoleo@gmail.com" class="link-item"
              >E-mail: coletapapaoleo@gmail.com</a
            >
          </li>
        </ul>

        <div class="social-icons">
          <a
            href="https://www.instagram.com/papaoleocoleta/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="social-icon"
          >
            <Image src={instagramIcon} alt="Instagram" loading="lazy" />
          </a>
          <a
            href={`https://wa.me/${import.meta.env.PUBLIC_WHATSAPP_NUMBER}?text=${encodeURIComponent("Olá! Gostaria de agendar uma coleta de óleo.")}`}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="WhatsApp"
            class="social-icon"
          >
            <Image src={whatsappIcon} alt="WhatsApp" loading="lazy" />
          </a>
        </div>
      </div>

      <nav class="footer-link-col" aria-labelledby="title-nav">
        <h4 id="title-nav" class="link-title">Navegação</h4>
        <ul class="link-list">
          <li><a href="/" class="link-item">Início</a></li>
          <li><a href="/#o-que-fazemos" class="link-item">Como Funciona</a></li>
          <li>
            <a href="/#quem-atendemos" class="link-item">Quem atendemos</a>
          </li>
          <li>
            <a href="/#cobertura" class="link-item">Onde atendemos</a>
          </li>
        </ul>
      </nav>

      <nav class="footer-link-col" aria-labelledby="title-info">
        <h4 id="title-info" class="link-title">Informações gerais</h4>
        <ul class="link-list">
          <li><a href="/faq" class="link-item">FAQ</a></li>
          <li>
            <a href="/politica-de-privacidade" class="link-item"
              >Política de Privacidade</a
            >
          </li>
        </ul>
      </nav>
    </div>

    <div class="footer-bottom">
      <div class="footer-logo">
        <Image
          src={logoV3}
          alt="Logo Papa Óleo - Coleta de Óleo de Cozinha"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</footer>

<style>
  @import "../styles/components-styles/footer.css";
</style>

<script src="/js/validacao.js" defer></script>
