---
const features = [
  {
    id: "coleta",
    title: "Retirada no Local",
    description:
      "Coletamos o seu óleo de cozinha usado. O processo é agendado para que você não tenha nenhum trabalho com o transporte ou descarte do material.",
    bullets: [
      "Fornecimento de bombonas adequadas.",
      "Rotas programadas para a sua região.",
      "Coleta rápida sem interromper sua rotina.",
    ],
    image: "/images/3_how-work_01_v2.svg",
  },
  {
    id: "preparacao",
    title: "Preparação do Material",
    description:
      "Todo o óleo recolhido passa por etapas de limpeza nas nossas instalações para a remoção completa de água e partículas sólidas da fritura.",
    bullets: [
      "Separação total de resíduos de alimentos.",
      "Extração da umidade do óleo.",
      "Armazenamento em tanques próprios.",
    ],
    image: "/images/3_how-work_02.svg",
  },
  {
    id: "reciclagem",
    title: "Processo de Reciclagem",
    description:
      "O resíduo é reinserido na indústria e ganha vida nova, servindo como matéria-prima principal para diversos setores.",
    bullets: [
      "Base para produção de biodiesel.",
      "Insumo para produtos de limpeza.",
      "Prevenção de contaminação da rede de esgoto.",
    ],
    image: "/images/3_how-work_03.svg",
  },
];
---

<section id="o-que-fazemos" class="process-section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Coleta de óleo usado</h2>
      <p class="section-subtitle">
        O ciclo completo do material: da retirada no seu endereço até o
        reaproveitamento.
      </p>
    </div>

    <div class="layout-grid">
      <div class="accordion-column">
        {
          features.map((feature, index) => (
            <div
              class={`feature-card ${index === 0 ? "active" : ""}`}
              data-image={feature.image}
            >
              <button
                class="card-header"
                aria-expanded={index === 0 ? "true" : "false"}
              >
                <div class="mobile-image-wrapper">
                  <img
                    src={feature.image}
                    alt={`Ilustração: ${feature.title}`}
                    loading="lazy"
                  />
                </div>

                <div class="header-row">
                  <h3 class="feature-title">{feature.title}</h3>
                  <div class="toggle-icon">
                    <svg
                      class="icon-plus"
                      width="12"
                      height="12"
                      viewBox="0 0 14 14"
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
                    >
                      <path
                        d="M7 1V13M1 7H13"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                      />
                    </svg>
                  </div>
                </div>
              </button>

              <div class="card-body">
                <div class="card-content">
                  <p class="feature-desc">{feature.description}</p>

                  <ul class="feature-bullets">
                    {feature.bullets.map((bullet) => (
                      <li>
                        <div class="bullet-icon">
                          <svg
                            width="10"
                            height="10"
                            viewBox="0 0 12 12"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                          >
                            <path
                              d="M10 3L4.5 8.5L2 6"
                              stroke="var(--bg-white)"
                              stroke-width="2"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                            />
                          </svg>
                        </div>
                        {bullet}
                      </li>
                    ))}
                  </ul>

                  <div class="accent-line" />
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <div class="visual-column">
        <div class="image-wrapper">
          <img
            id="dynamic-feature-image"
            src={features[0].image}
            alt="Ilustração do processo de coleta e reciclagem de óleo de cozinha"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .process-section {
    padding: 4rem 1.5rem;
    background-color: var(--bg-light);
    color: var(--charcoal);
  }

  @media (min-width: 768px) {
    .process-section {
      padding: 6rem 1.5rem;
    }
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .layout-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 992px) {
    .layout-grid {
      grid-template-columns: 4.5fr 5.5fr;
      gap: 3rem;
      align-items: stretch;
    }
  }

  .accordion-column {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .feature-card {
    background-color: var(--bg-white);
    border-radius: 1.25rem;
    padding: 0.625rem 0.625rem 0 0.625rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
    border: 1px solid rgba(0, 0, 0, 0.05);
    transition: all 0.3s ease;
  }

  @media (min-width: 992px) {
    .feature-card {
      padding: 1.25rem 1.25rem 0 1.25rem;
    }
  }

  .card-header {
    width: 100%;
    display: flex;
    flex-direction: column;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0 0 1rem 0;
    text-align: left;
  }

  .mobile-image-wrapper {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: var(--bg-light);
    border-radius: 0.75rem;
    margin-bottom: 1.25rem;
    overflow: hidden;
  }

  .mobile-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .visual-column {
    display: none;
  }

  @media (min-width: 992px) {
    .mobile-image-wrapper {
      display: none;
    }
    .visual-column {
      display: flex;
      flex-direction: column;
      height: 100%;
      min-height: 0;
    }
  }

  .header-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .feature-title {
    font-size: 1.125rem;
    font-family: var(--font-sans);
    font-weight: 700;
    color: var(--brand-gray);
    margin: 0;
    transition: font-weight 0.3s ease;
  }

  @media (min-width: 768px) {
    .feature-title {
      font-size: 1.25rem;
    }
  }

  .toggle-icon {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background-color: rgba(0, 0, 0, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--charcoal);
    transition: all 0.3s ease;
  }

  .icon-plus {
    transition: transform 0.3s ease;
  }

  .feature-card.active .icon-plus {
    transform: rotate(45deg);
  }

  .feature-card.active .toggle-icon {
    background-color: var(--brand-yellow);
    color: var(--bg-white);
  }

  .card-body {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.4s cubic-bezier(0.25, 0.4, 0.25, 1);
  }

  .feature-card.active .card-body {
    grid-template-rows: 1fr;
  }

  .card-content {
    overflow: hidden;
  }

  .feature-desc {
    font-size: 0.875rem;
    font-family: var(--font-sans);
    color: rgba(18, 18, 18, 0.7);
    line-height: 1.5;
    margin: 0 0 1rem 0;
  }

  .feature-bullets {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .feature-bullets li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-family: var(--font-sans);
    font-weight: 500;
    color: var(--charcoal);
    line-height: 1.4;
  }

  .bullet-icon {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background-color: var(--brand-yellow);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 0.125rem;
  }

  .accent-line {
    height: 3px;
    width: 100%;
    background-color: var(--brand-yellow);
    border-radius: 9999px;
    margin-bottom: 1.25rem;
  }

  .image-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    background-color: var(--bg-light);
    border-radius: 1.5rem;
  }

  .image-wrapper img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    z-index: 10;

    transform: scale(1.15);
    transition: opacity 0.3s ease-in-out;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const cards = document.querySelectorAll(".feature-card");
    const dynamicImage = document.getElementById(
      "dynamic-feature-image",
    ) as HTMLImageElement;

    if (!cards.length) return;

    function activateCard(card: Element) {
      cards.forEach((el) => {
        el.classList.remove("active");
        el.querySelector(".card-header")?.setAttribute(
          "aria-expanded",
          "false",
        );
      });

      card.classList.add("active");
      card.querySelector(".card-header")?.setAttribute("aria-expanded", "true");

      if (dynamicImage) {
        const newImageSrc = card.getAttribute("data-image");
        if (newImageSrc) {
          dynamicImage.style.opacity = "0.3";
          setTimeout(() => {
            dynamicImage.src = newImageSrc;
            dynamicImage.style.opacity = "1";
          }, 200);
        }
      }
    }

    cards.forEach((card) => {
      const header = card.querySelector(".card-header");

      header?.addEventListener("click", () => {
        const isActive = card.classList.contains("active");

        if (isActive && window.innerWidth >= 992) {
          return;
        }

        if (isActive && window.innerWidth < 992) {
          card.classList.remove("active");
          header.setAttribute("aria-expanded", "false");
          return;
        }

        activateCard(card);
      });
    });

    const mediaQuery = window.matchMedia("(min-width: 992px)");

    mediaQuery.addEventListener("change", (e) => {
      if (e.matches) {
        const hasActive = Array.from(cards).some((card) =>
          card.classList.contains("active"),
        );

        if (!hasActive) {
          activateCard(cards[0]);
        }
      }
    });
  });
</script>
