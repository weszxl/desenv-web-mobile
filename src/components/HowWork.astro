---
/**
 * Componente: HowWork.astro (Como Funciona)
 *
 * O que faz:
 * Este componente apresenta um guia com as etapas do processo ("Retirada", "Preparação", "Reciclagem").
 * Usa uma estrutura de acordeões (sanfonas expansíveis) na esquerda (ou no formato móvel empilhado),
 * e, nas resoluções maiores, apresenta uma imagem de destaque na direita que interage e muda dinamicamente via JS.
 *
 * Onde é usado:
 * Normalmente é empregado na landing page do site (index.astro) servindo como
 * a "vitrine" visual explicando detalhadamente o modelo de negócio da coleta.
 */

// Importação das imagens utilizadas no painel (neste exemplo a mesma imagem simula as etapas)
import imgHowWork01 from "../assets/images/3_how-work_01.png";
import imgHowWork02 from "../assets/images/3_how-work_02.png";
import imgHowWork03 from "../assets/images/3_how-work_03.png";

/**
 * Array de dados estruturados para renderização repetível (DRY).
 * Cada 'feature' (objeto) representa um "cartão/acordeão" com sua respectiva lista de descrições e arte.
 */
const features = [
  {
    id: "coleta",
    title: "Retirada no Local",
    description:
      "Coletamos o seu óleo de cozinha usado. O processo é agendado para que você não tenha nenhum trabalho com o transporte ou descarte do material.",
    bullets: [
      "Fornecimento de bombonas adequadas.",
      "Rotas programadas para a sua região.",
      "Coleta rápida sem interromper sua rotina.",
    ],
    image: imgHowWork01,
  },
  {
    id: "preparacao",
    title: "Preparação do Material",
    description:
      "Todo o óleo recolhido passa por etapas de limpeza nas nossas instalações para a remoção completa de água e partículas sólidas da fritura.",
    bullets: [
      "Separação total de resíduos de alimentos.",
      "Extração da umidade do óleo.",
      "Armazenamento em tanques próprios.",
    ],
    image: imgHowWork02,
  },
  {
    id: "reciclagem",
    title: "Processo de Reciclagem",
    description:
      "O resíduo é reinserido na indústria e ganha vida nova, servindo como matéria-prima principal para diversos setores.",
    bullets: [
      "Base para produção de biodiesel.",
      "Insumo para produtos de limpeza.",
      "Prevenção de contaminação da rede de esgoto.",
    ],
    image: imgHowWork03,
  },
];
---

<section id="o-que-fazemos" class="process-section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Como Funciona a Nossa Coleta</h2>
      <p class="section-subtitle">
        Da retirada no seu endereço até o reaproveitamento.
      </p>
    </div>

    <div class="layout-grid">
      <div class="accordion-column">
        {
          features.map((feature, index) => (
            <div
              class={`feature-card ${index === 0 ? "active" : ""}`}
              data-image={feature.image.src}
            >
              <button
                class="card-header"
                aria-expanded={index === 0 ? "true" : "false"}
              >
                <span class="mobile-image-wrapper">
                  <img
                    src={feature.image.src}
                    alt={`Ilustração: ${feature.title}`}
                    loading="lazy"
                  />
                </span>

                <span class="header-row">
                  <span class="feature-title">{feature.title}</span>
                  <span class="toggle-icon">
                    <svg
                      class="icon-plus"
                      width="12"
                      height="12"
                      viewBox="0 0 14 14"
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
                      aria-hidden="true"
                    >
                      <path
                        d="M7 1V13M1 7H13"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                      />
                    </svg>
                  </span>
                </span>
              </button>

              <div class="card-body">
                <div class="card-content">
                  <p class="feature-desc">{feature.description}</p>

                  <ul class="feature-bullets">
                    {feature.bullets.map((bullet) => (
                      <li>
                        <div class="bullet-icon">
                          <svg
                            width="10"
                            height="10"
                            viewBox="0 0 12 12"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                            aria-hidden="true"
                          >
                            <path
                              d="M10 3L4.5 8.5L2 6"
                              stroke="var(--bg-white)"
                              stroke-width="2"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                            />
                          </svg>
                        </div>
                        {bullet}
                      </li>
                    ))}
                  </ul>

                  <div class="accent-line" />
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <div class="visual-column">
        <div class="image-wrapper">
          <img
            id="dynamic-feature-image"
            src={features[0].image.src}
            alt="Ilustração do processo de coleta e reciclagem de óleo de cozinha"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @import "../styles/components-styles/how_work.css";
</style>

<script src="../scripts/how_work.js"></script>
