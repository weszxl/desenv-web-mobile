---
import { Image } from "astro:assets";
import step1 from "../assets/images/5_how-recycle_step1.svg";
import step2 from "../assets/images/5_how-recycle_step2.svg";
import step3 from "../assets/images/5_how-recycle_step3.svg";
import step4 from "../assets/images/5_how-recycle_step4.svg";

const steps = [
  {
    number: "1º",
    title: "Espere o óleo esfriar",
    description:
      "Após a fritura, deixe o líquido esfriar completamente antes do descarte para evitar acidentes ou o derretimento do recipiente.",
    icon: step1,
  },
  {
    number: "2º",
    title: "Armazene em um recipiente",
    description:
      "Utilize as nossas bombonas ou garrafas PET bem fechadas. Não é necessário coar.",
    icon: step2,
  },
  {
    number: "3º",
    title: "Coloque em um lugar adequado",
    description:
      "Mantenha o material armazenado em um local seguro, arejado e protegido do sol ou fontes de calor até o dia da retirada.",
    icon: step3,
  },
  {
    number: "4º",
    title: "Nos chame",
    description:
      "Recipiente cheio? Envie uma mensagem com a quantidade e o bairro. Seu endereço entra na nossa próxima rota programada.",
    icon: step4,
  },
];
---

<section id="preparacao" class="prep-section noise-overlay">
  <div class="bg-gradient-overlay"></div>
  <div class="bg-blob blob-green prep-blob-1"></div>
  <div class="bg-blob blob-yellow prep-blob-2"></div>

  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Como descartar o seu óleo usado</h2>
      <p class="section-subtitle">
        Etapas simples para garantir que a coleta seja feita de forma eficiente.
      </p>
    </div>

    <div class="zigzag-wrapper">
      {
        steps.map((step, index) => {
          const isCardLeft = index % 2 === 0;

          return (
            <div
              class={`step-row ${isCardLeft ? "layout-card-left" : "layout-card-right"}`}
            >
              <div class="step-content">
                <div class="step-badge">
                  <span class="dot">&bull;</span> PASSO {step.number}
                </div>
                <h3 class="step-title">{step.title}</h3>
                <p class="step-desc">{step.description}</p>
              </div>

              <div class="step-image-wrapper">
                <Image src={step.icon} alt={step.title} loading="lazy" />
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .prep-section {
    position: relative;
    padding: 4rem 0;
    background-color: var(--bg-white);
    color: var(--charcoal);
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .prep-section {
      padding: 6rem 0;
    }
  }

  .prep-blob-1 {
    top: 10%;
    left: 5%;
    width: 8rem;
    height: 8rem;
  }

  .prep-blob-2 {
    bottom: 10%;
    right: 5%;
    width: 10rem;
    height: 10rem;
  }

  .container {
    position: relative;
    z-index: 10;
    max-width: 1024px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .zigzag-wrapper {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .zigzag-wrapper {
      gap: 3rem;
    }
  }

  .step-row {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2rem;
  }

  .step-row:not(:last-child) {
    border-bottom: 2px dashed rgba(0, 0, 0, 0.1);
    padding-bottom: 2rem;
  }

  @media (min-width: 768px) {
    .step-row {
      gap: 2.5rem;
    }

    .step-row:not(:last-child) {
      border-bottom: none;
      padding-bottom: 0;
    }
  }

  @media (min-width: 768px) {
    .layout-card-left {
      flex-direction: row;
    }

    .layout-card-right {
      flex-direction: row-reverse;
    }
  }

  .step-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: 100%;
    max-width: 450px;
    transition: transform 0.3s ease;
  }

  @media (min-width: 768px) {
    .step-content {
      width: 100%;
      max-width: 450px;
      text-align: left;
      align-items: flex-start;
    }
  }

  .step-content:hover {
    transform: translateY(-5px);
  }

  .step-title {
    font-size: 1.125rem;
    font-family: var(--font-sans);
    font-weight: 700;
    color: var(--brand-gray);
    margin: 0 0 0.5rem 0;
    line-height: 1.2;
  }

  @media (min-width: 768px) {
    .step-title {
      font-size: 1.25rem;
    }
  }

  .step-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 1rem;
    border-radius: 999px;
    background-color: rgba(65, 163, 76, 0.1);
    color: var(--brand-green);
    font-weight: 700;
    font-size: 0.875rem;
    font-family: var(--font-sans);
    margin-bottom: 1rem;
  }

  .step-badge .dot {
    margin-right: 0.5rem;
    font-size: 1.2em;
  }

  .step-desc {
    font-size: 0.875rem;
    font-family: var(--font-sans);
    color: rgba(18, 18, 18, 0.7);
    line-height: 1.5;
    margin: 0;
  }

  @media (min-width: 768px) {
    .step-desc {
      font-size: 1rem;
      line-height: 1.6;
    }
  }

  .step-image-wrapper {
    width: 100%;
    max-width: 150px;
  }

  @media (min-width: 768px) {
    .step-image-wrapper {
      max-width: 250px;
      width: 100%;
      display: flex;
      justify-content: center;
    }
  }

  .step-image-wrapper img {
    width: 100%;
    height: auto;
    object-fit: contain;
  }
</style>
