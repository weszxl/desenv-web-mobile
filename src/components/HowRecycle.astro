---
/**
 * Componente: HowRecycle.astro
 * 
 * O que faz:
 * Este componente renderiza a seção "Como descartar o seu óleo usado".
 * Ele apresenta um passo a passo (step-by-step) de como o usuário deve preparar 
 * e armazenar o óleo antes da coleta, renderizando de forma dinâmica 
 * os cartões em um layout estilo "zig-zag" (alternando texto e imagem).
 * 
 * Onde é usado:
 * Normalmente na landing page principal (ex: src/pages/index.astro) 
 * para educar os clientes sobre o processo correto de reciclagem.
 */

// Importa o componente nativo e otimizado de imagens do Astro
import { Image } from "astro:assets";

// Importa as ilustrações/ícones SVG para cada passo do processo
import step1 from "../assets/images/5_how-recycle_step1.svg";
import step2 from "../assets/images/5_how-recycle_step2.svg";
import step3 from "../assets/images/5_how-recycle_step3.svg";
import step4 from "../assets/images/5_how-recycle_step4.svg";

/**
 * Array contendo os dados de cada etapa do processo.
 * Usar uma estrutura de dados (array de objetos) facilita a renderização 
 * e futuras manutenções, já que separamos o "conteúdo" da "marcação HTML".
 */
const steps = [
  {
    number: "1º",
    title: "Espere o óleo esfriar",
    description:
      "Após a fritura, deixe o líquido esfriar completamente antes do descarte para evitar acidentes ou o derretimento do recipiente.",
    icon: step1,
  },
  {
    number: "2º",
    title: "Armazene em um recipiente",
    description:
      "Utilize as nossas bombonas ou garrafas PET bem fechadas. Não é necessário coar.",
    icon: step2,
  },
  {
    number: "3º",
    title: "Coloque em um lugar adequado",
    description:
      "Mantenha o material armazenado em um local seguro, arejado e protegido do sol ou fontes de calor até o dia da retirada.",
    icon: step3,
  },
  {
    number: "4º",
    title: "Nos chame",
    description:
      "Recipiente cheio? Envie uma mensagem com a quantidade e o bairro. Seu endereço entra na nossa próxima rota programada.",
    icon: step4,
  },
];
---

<section id="preparacao" class="prep-section">
  <div class="container">
    
    <div class="section-header">
      <h2 class="section-title">Como descartar o seu óleo usado</h2>
      <p class="section-subtitle">
        Etapas simples para garantir que a coleta seja feita de forma eficiente.
      </p>
    </div>

    <div class="zigzag-wrapper">
      {
        steps.map((step, index) => {
          const isCardLeft = index % 2 === 0;

          return (
            
            <div
              class={`step-row ${isCardLeft ? "layout-card-left" : "layout-card-right"}`}
            >
              <!-- Conteúdo de Texto do Passo -->
              <div class="step-content">
                <div class="step-badge">
                  <span class="dot">&bull;</span> PASSO {step.number}
                </div>
                <h3 class="step-title">{step.title}</h3>
                <p class="step-desc">{step.description}</p>
              </div>

              <!-- Conteúdo da Imagem Ilustrativa do Passo -->
              <div class="step-image-wrapper">
                <!-- 
                  loading="lazy" atrasa o download da imagem até o usuário rolar 
                  perto da tela onde ela está, economizando dados e tempo de carga.
                -->
                <Image src={step.icon} alt={step.title} loading="lazy" />
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  @import "../styles/components-styles/how_recycle.css";
</style>
