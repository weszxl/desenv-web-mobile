---
/**
 * Componente: Service.astro (Seção de Serviços)
 *
 * O que faz:
 * Renderiza uma seção em formato de acordeão horizontal expansível (no layout desktop) ou
 * em lista empilhada (no mobile), apresentando os 4 perfis de serviços oferecidos:
 * Comercial, Condomínio, Residencial e Industrial.
 * Cada cartão exibe uma imagem de fundo, ícone, título e, quando o usuário clica e o torna "ativo",
 * expande suavemente revelando a descrição detalhada e o botão de agendamento do WhatsApp.
 *
 * Onde é usado:
 * Na página inicial (index.astro), atuando como um dos principais call-to-actions (CTA)
 * altamente segmentado para que o cliente identifique imediatamente seu perfil e faça o contato.
 */

// Importação do componente de Imagem otimizada nativo do framework Astro
import { Image } from "astro:assets";

// Importação manual das imagens de fundo (Background) que ilustram cada serviço visualmente
import img01 from "../assets/images/4_services_01.png";
import img02 from "../assets/images/4_services_02.png";
import img03 from "../assets/images/4_services_03.png";
import img04 from "../assets/images/4_services_04.png";

// Importação manual dos Ícones vetoriais (SVG amarelos) que representam as modalidades
import icon01 from "../assets/images/4_services-icon_01.svg";
import icon02 from "../assets/images/4_services-icon_02.svg";
import icon03 from "../assets/images/4_services-icon_03.svg";
import icon04 from "../assets/images/4_services-icon_04.svg";

/**
 * Matriz (Array) de dados dos Serviços.
 * Cada objeto contém todas as informações (textos e imagens) que preencherão um cartão na interface,
 * facilitando a manutenção e a renderização dinâmica por loop (.map).
 */
const services = [
  {
    id: 1,
    title: "Coleta Comercial",
    description:
      "Retirada programada de resíduos gordurosos para restaurantes, bares e comércios de alimentação.",
    image: img01,
    icon: icon01,
  },
  {
    id: 2,
    title: "Coleta em Condomínio",
    description:
      "Sistemas de descarte ecológico e bombonas sob medida para edifícios residenciais.",
    image: img02,
    icon: icon02,
  },
  {
    id: 3,
    title: "Coleta Residencial",
    description:
      "Atendimento agendado para descarte correto diretamente na sua casa.",
    image: img03,
    icon: icon03,
  },
  {
    id: 4,
    title: "Coleta Industrial",
    description:
      "Logística e destinação correta de grandes volumes de óleo para indústrias e fábricas.",
    image: img04,
    icon: icon04,
  },
];
---

<!-- Âncora referenciada pelo menu superior (Header) para rolar a página exatamente até esta parte -->
<section id="quem-atendemos" class="services-section">
  <!-- Container centralizador limitador da largura máxima do conteúdo em telas Ultra Wide -->
  <div class="services-container">
    <!-- Cabeçalho textual introdutório da seção -->
    <div class="services-header">
      <h2 class="section-title">Serviços de Coleta de Óleo</h2>
      <p class="section-subtitle">
        Encontre a solução ideal para a sua necessidade e agende a retirada.
      </p>
    </div>

    <!-- Div principal (Pai) que engloba a lógica mecânica do Acordeão (Via CSS Flex-Grow e JS) -->
    <div class="accordion-wrapper" id="coleta-accordion">
      {
        /* Loop inteligente (.map) que percorre nossa matriz 'services' gerando as tags HTML dinamicamente */
        services.map((service, index) => (
          // O primeiro elemento (index === 0) sempre ganha a classe de brinde "active" para nascer aberto por padrão
          <div class={`accordion-card ${index === 0 ? "active" : ""}`}>
            <Image
              src={service.image}
              alt={`Serviço de ${service.title} de óleo`}
              class="card-bg-image"
              loading="lazy"
            />

            <div class="card-overlay" />

            <div class="card-content">
              <div class="card-top">
                <div class="card-icon">
                  <Image
                    src={service.icon}
                    alt={`Ícone ${service.title}`}
                    loading="lazy"
                  />
                </div>
                <h3 class="card-title">{service.title}</h3>
              </div>

              <div class="card-bottom-reveal">
                <p class="card-description">{service.description}</p>

                <a
                  href={`https://wa.me/${import.meta.env.PUBLIC_WHATSAPP_NUMBER}?text=${encodeURIComponent("Olá! Tenho interesse no serviço de " + service.title + " de óleo. Como podemos agendar?")}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn-schedule"
                >
                  Agendar Coleta
                </a>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<!-- Importação modular do CSS contendo as pesadas regras de transição (flex-grow) deste acordeão -->
<style>
  @import "../styles/components-styles/service.css";
</style>

<!-- Script isolado (JS) que "escuta" o clique do usuário em um cartão, fechando os demais e ativando-o -->
<script src="../scripts/service.js"></script>
