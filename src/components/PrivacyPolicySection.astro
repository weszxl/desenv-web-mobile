---
// src/components/PrivacyPolicySection.astro

const policies = [
  {
    title: "1. Quais dados coletamos",
    text: "Coletamos apenas os dados que você insere voluntariamente em nosso formulário de contato: nome e número de telefone/WhatsApp. Caso nosso site utilize ferramentas de medição de acessos, dados básicos de navegação (como modelo do dispositivo e cidade de acesso) podem ser registrados de forma anônima."
  },
  {
    title: "2. Para que usamos os seus dados",
    text: "As informações captadas são utilizadas exclusivamente para o andamento da nossa operação de coleta. Usamos seu WhatsApp para estabelecer contato comercial, agendar as rotas de retirada, alinhar a logística no seu endereço e enviar informações pertinentes ao serviço."
  },
  {
    title: "3. Compartilhamento de dados",
    text: "Os seus dados são para uso estrito da nossa equipe logística e de atendimento. Nós não vendemos, alugamos ou repassamos as suas informações de contato para terceiros em nenhuma hipótese, salvo por obrigação legal ou ordem judicial."
  },
  {
    title: "4. Seus direitos",
    text: "Você possui controle sobre as suas informações. A qualquer momento, você pode nos enviar uma mensagem no WhatsApp ou e-mail solicitando a exclusão do seu número da nossa base de contatos operacionais e o seu registro será apagado."
  }
];
---

<section class="privacy-section">
  
  <div class="privacy-background">
    <div class="bg-gradient-overlay"></div>
    <div class="bg-blob blob-green privacy-blob-1"></div>
    <div class="bg-blob blob-yellow privacy-blob-2"></div>
  </div>

  <div class="privacy-noise-wrapper noise-overlay"></div>

  <div class="privacy-container">
    
    <div class="privacy-grid">
      
      <div class="privacy-sidebar">
        <div class="sidebar-header">
          <span class="subtitle">TRANSPARÊNCIA E SEGURANÇA</span>
          <h2 class="title">Política de Privacidade</h2>
        </div>

        <div class="support-card">
          <h3 class="support-title">Ficou com alguma dúvida?</h3>
          <p class="support-text">Caso tenha qualquer dúvida sobre como tratamos os seus dados, entre em contato conosco.</p>
          
          <a href="mailto:papaoleoColeta@gmail.com" class="btn-support">
            Enviar E-mail
          </a>
        </div>
      </div>

      <div class="privacy-content">
        <div class="policy-group">
          {policies.map((policy) => (
            <div class="policy-card">
              <h3 class="policy-title">{policy.title}</h3>
              <p class="policy-text">{policy.text}</p>
            </div>
          ))}
        </div>
      </div>

    </div>

  </div>
</section>

<style>
  .privacy-section {
    position: relative;
    padding: 8rem 0 6rem 0;
    background-color: var(--bg-white);
    color: var(--charcoal);
    min-height: 100vh;
  }

  @media (min-width: 768px) {
    .privacy-section {
      padding: 10rem 0 8rem 0;
    }
  }

  /* --- TRANCANDO O RUÍDO DE FORMA SEGURA --- */
  .privacy-noise-wrapper {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 50;
  }

  /* --- TRANCANDO OS BLOBS DE FORMA SEGURA --- */
  .privacy-background {
    position: absolute;
    inset: 0;
    overflow: hidden; 
    pointer-events: none;
    z-index: 1;
  }

  .privacy-blob-1 {
    top: 5%;
    left: -5%;
    width: 15rem;
    height: 15rem;
  }

  .privacy-blob-2 {
    bottom: 10%;
    right: -5%;
    width: 20rem;
    height: 20rem;
  }

  .privacy-container {
    position: relative;
    z-index: 10;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .privacy-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 992px) {
    .privacy-grid {
      grid-template-columns: 3.5fr 8.5fr;
      gap: 5rem;
      align-items: start;
    }
  }

  /* --- SIDEBAR INDEPENDENTE E FIXA --- */
  .privacy-sidebar {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-self: start; 
    height: max-content;
  }

  @media (min-width: 992px) {
    .privacy-sidebar {
      position: sticky;
      top: 8rem; 
    }
  }

  .sidebar-header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .subtitle {
    font-size: 0.75rem;
    font-weight: 700;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--charcoal);
    opacity: 0.6;
  }

  .title {
    font-size: 2.5rem;
    font-weight: 900;
    font-family: var(--font-sans);
    color: var(--brand-gray); 
    letter-spacing: -0.025em;
    margin: 0;
    line-height: 1.1;
  }

  @media (min-width: 768px) {
    .title { font-size: 3rem; }
  }

  /* Card de Suporte */
  .support-card {
    background-color: transparent;
    border-radius: 1.25rem;
    padding: 2rem;
    border: 1px solid rgba(0, 0, 0, 0.1);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .support-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--charcoal);
    margin: 0 0 0.25rem 0;
  }

  .support-text {
    font-size: 0.875rem;
    color: var(--charcoal);
    opacity: 0.8;
    margin: 0 0 1.5rem 0;
  }

  .btn-support {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--brand-green);
    color: var(--bg-white);
    padding: 0.875rem 1.5rem;
    border-radius: 9999px;
    font-weight: 700;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: transform 0.2s, background-color 0.2s;
    width: 100%;
  }

  .btn-support:hover {
    transform: scale(1.02);
  }

  /* --- POLICY CARDS --- */
  .policy-group {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .policy-card {
    background-color: transparent; 
    border-radius: 0.75rem;
    border: 1px solid rgba(0, 0, 0, 0.1); 
    padding: 1.25rem;
    transition: border-color 0.3s ease;
  }

  .policy-card:hover {
    border-color: rgba(100, 180, 69, 0.3);
  }

  @media (min-width: 768px) {
    .policy-card { padding: 1.5rem; }
  }

  .policy-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--charcoal);
    line-height: 1.4;
    margin: 0 0 0.75rem 0;
  }

  .policy-text {
    margin: 0;
    font-size: 0.9375rem;
    color: var(--charcoal);
    opacity: 0.8;
    line-height: 1.6;
  }
</style>