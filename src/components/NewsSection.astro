---
/**
 * Componente: NewsSection.astro (Seção de Blog/Notícias)
 * 
 * O que faz:
 * Renderiza uma seção de blog contendo notícias, dicas e artigos relacionados à reciclagem.
 * Possui um array interno de notícias e realiza uma ordenação por data real (mais recentes primeiro)
 * usando Javascript antes de renderizar os cartões em HTML.
 * O componente também cria o menu de filtros (Categorias) e os botões "Exibir Mais".
 * 
 * Onde é usado:
 * Normalmente é empregado na parte inferior da landing page (index.astro), 
 * ajudando com SEO e mantendo os usuários engajados com atualizações.
 */

// Importa o otimizador nativo de imagens do Astro
import { Image } from "astro:assets";

import img1 from "../assets/images/notice_gazeta24horasrio.com.br-descarte-de-oleo-de-cozinha-ainda-causa-entupimentos-nas-cidades.png";
import img2 from "../assets/images/notice_globorural.globo.com-pesquisa-indica-resultados-positivos-do-oleo-de-cozinha-usado-na-producao-de-biodiesel.png";
import img3 from "../assets/images/notice_tribunadosertao.com.br-oleo-de-cozinha-descartado-de-forma-irregular-ameaca-solo-e-lencois-freaticos.png";
import img4 from "../assets/images/tip_sudema.pb.gov.br-descarte-incorreto-do-oleo-de-cozinha-contamina-o-meio-ambiente-saiba-o-que-fazer.png";
import img5 from "../assets/images/tip_binatural.com.br-como-o-oleo-de-cozinha-deve-ser-descartado.png";
import img6 from "../assets/images/tip_ciclovivo.com.br-cartilha-ensina-a-usar-e-descartar-oleo-de-cozinha.png";
import img7 from "../assets/images/notice_agronoticia.com.br-demanda-da-industria-de-biodiesel-por-oleo-de-cozinha-usado-dispara.png";
import img8 from "../assets/images/notice_globorural.globo.com-demanda-da-industria-de-biodiesel-por-oleo-de-cozinha-usado-dispara.png";

/**
 * Array de Notícias (Database Mock).
 * Cada objeto representa um cartão de matéria.
 * O campo 'info' guarda a data e a categoria em formato de string separada por traço.
 */
const newsItems = [
  {
    image: img1,
    title: "Descarte incorreto de óleo causa entupimentos",
    info: "10 Mar 2026 - Notícia",
    description:
      "Descubra como o descarte inadequado de óleo de cozinha nas pias e ralos está causando problemas crônicos nas redes de esgoto e gerando prejuízos.",
    link: "https://gazeta24horasrio.com.br/2026/03/14/descarte-de-oleo-de-cozinha-ainda-causa-entupimentos-nas-cidades",
  },
  {
    image: img2,
    title: "Pesquisa indica resultados positivos na produção de biodiesel",
    info: "11 Jan 2026 - Artigo",
    description:
      "Estudos recentes demonstram a viabilidade e os benefícios crescentes de se utilizar óleo residual para impulsionar a matriz de energia sustentável.",
    link: "https://globorural.globo.com/biocombustiveis/noticia/2026/01/pesquisa-indica-resultados-positivos-do-oleo-de-cozinha-usado-na-producao-de-biodiesel.ghtml",
  },
  {
    image: img3,
    title: "Óleo descartado ameaça lençóis freáticos",
    info: "11 jun 2026 - Notícia",
    description:
      "O descarte irregular no solo tem um impacto direto nos aquíferos, comprometendo seriamente o abastecimento de água potável em diversas regiões.",
    link: "https://www.tribunadosertao.com.br/geral/2026/06/11/919445-oleo-de-cozinha-descartado-de-forma-irregular-ameaca-solo-e-lencois-freaticos",
  },
  {
    image: img4,
    title: "Descarte incorreto contamina o meio ambiente",
    info: "16 Ago 2022 - Dica",
    description:
      "Veja os impactos diretos do descarte inadequado na natureza e confira um guia rápido com as melhores atitudes para adotar no seu dia a dia.",
    link: "https://sudema.pb.gov.br/noticias/descarte-incorreto-do-oleo-de-cozinha-contamina-o-meio-ambiente-saiba-o-que-fazer",
  },
  {
    image: img5,
    title: "Como o óleo de cozinha deve ser descartado",
    info: "24 Mar 2026 - Dica",
    description:
      "Aprenda o passo a passo correto para armazenar e reciclar seu óleo de fritura em casa.",
    link: "https://binatural.com.br/como-o-oleo-de-cozinha-deve-ser-descartado/",
  },
  {
    image: img6,
    title: "Cartilha ensina a usar e descartar óleo de cozinha",
    info: "20 Dez 2025 - Dica",
    description:
      "Novos materiais educativos ajudam a conscientizar sobre o processo de reciclagem do óleo vegetal.",
    link: "https://ciclovivo.com.br/mao-na-massa/faca-voce-mesmo/cartilha-ensina-a-usar-e-descartar-oleo-de-cozinha/",
  },
  {
    image: img7,
    title: "Demanda da indústria de biodiesel por óleo usado dispara",
    info: "13 Nov 2023 - Notícia",
    description:
      "O setor de biocombustíveis registra um aumento expressivo na procura por resíduos residenciais.",
    link: "https://agronoticia.com.br/noticia/22110/demanda-da-industria-de-biodiesel-por-oleo-de-cozinha-usado-dispara.html",
  },
  {
    image: img8,
    title: "Óleo usado ganha força na produção de biodiesel",
    info: "14 Nov 2023 - Notícia",
    description:
      "Mercado se aquece e a coleta seletiva de óleo de cozinha se torna cada vez mais lucrativa e sustentável.",
    link: "https://globorural.globo.com/agricultura/noticia/2023/11/demanda-da-industria-de-biodiesel-por-oleo-de-cozinha-usado-dispara.ghtml",
  },
];

const monthMap = {
  jan: 0, fev: 1, mar: 2, abr: 3, mai: 4, jun: 5,
  jul: 6, ago: 7, set: 8, out: 9, nov: 10, dez: 11,
};

newsItems.sort((a, b) => {
  const parseDate = (infoStr) => {
    const datePart = infoStr.split("-")[0].trim().toLowerCase();
    const parts = datePart.split(" ");
    
    const day = parseInt(parts[0], 10);
    const month = monthMap[parts[1]];
    const year = parseInt(parts[2], 10);
    
    return new Date(year, month, day).getTime();
  };
  
  return parseDate(b.info) - parseDate(a.info);
});
---

<section class="news-section" id="noticias">
  <div class="news-container">
    
    <div class="blog-header-container">
      <div class="blog-header-title">
        <h2 class="section-title">Blog</h2>
      </div>
      <p class="section-subtitle">
        Fique por dentro das novidades, dicas e artigos sobre sustentabilidade.
      </p>
    </div>

    <!-- 
      Botões de Filtro.  
    -->
    <div class="blog-filters">
      <button class="filter-btn active" data-filter="all">Todos</button>
      <button class="filter-btn" data-filter="noticia">Notícias</button>
      <button class="filter-btn" data-filter="artigo">Artigos</button>
      <button class="filter-btn" data-filter="dica">Dicas</button>
    </div>

    <!-- Container de notícias -->
    <div class="blog-grid" id="blog-grid">
      {
        newsItems.map((item) => {
          // Extrai o tipo (categoria) a partir da string bruta. Ex: de "10 Mar - Notícia" tira apenas "Notícia"
          // O replace com Regex remove todos os acentos (Ex: Notícia -> noticia) para bater perfeitamente com os data-filters dos botões acima
          const category = item.info
            .split("-")[1]
            .trim()
            .toLowerCase()
            .normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "");

          return (
            // <article> envelopa cada notícia isolada
            <article class="blog-card" data-category={category}>
              <!-- Capa visual da Notícia -->
              <div class="blog-image-wrapper">
                <Image src={item.image} alt={item.title} class="blog-image" />
              </div>

              <div class="blog-content">
                <h3 class="blog-title">{item.title}</h3>
                <span class="blog-date">{item.info}</span>
                <p class="blog-description">{item.description}</p>

                <a href={item.link} class="blog-link" target="_blank" rel="noopener noreferrer">
                  Saiba mais
                  <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path d="M5 12h14M12 5l7 7-7 7" />
                  </svg>
                </a>
              </div>
            </article>
          );
        })
      }
    </div>

    <!-- 
       (Paginação). 
    -->
    <div
      class="load-more-container"
      style="margin-top: 3rem; display: flex; justify-content: center;"
    >
      <button class="filter-btn" id="load-more-btn">Exibir mais</button>
    </div>
  </div>
</section>

<style>
  @import "../styles/components-styles/news_section.css";
</style>

<script src="../scripts/news_section.js"></script>
