---
/**
 * Componente: Header.astro
 * 
 * O que faz:
 * Este componente renderiza o cabeçalho superior (navbar) do site.
 * Ele engloba:
 * - A logomarca da empresa (com variação para quando o menu sofre rolagem).
 * - O menu de navegação com links internos (Início, Como funciona, etc).
 * - Um botão de CTA (Call to Action) para formulário de contato.
 * - Um menu hambúrguer interativo para navegação em dispositivos móveis.
 * 
 * Onde é usado:
 * É inserido no layout principal/global do projeto (como BaseLayout.astro) 
 * para estar sempre presente no topo de todas as páginas do site.
 */

import { Image } from "astro:assets";
// Importa as duas versões da logo para serem alternadas via CSS/JS
import logoV1 from "../assets/images/logo_v1.svg"; // Logo padrão (fundo claro/transparente)
import logoV2 from "../assets/images/logo_v2.svg"; // Logo para quando a barra rola (fundo sólido)

// Array contendo os links do menu para renderização dinâmica (DRY - Don't Repeat Yourself)
const navLinks = [
  { label: "Início", href: "/" },
  { label: "Como funciona", href: "/#o-que-fazemos" },
  { label: "Quem atendemos", href: "/#quem-atendemos" },
  { label: "Onde atendemos", href: "/#cobertura" },
];
---

<!-- 
  Barra de navegação principal.
  Possui o id="main-nav" para ser capturada e manipulada pelo script (header.js).
-->
<nav id="main-nav" class="navbar">
  <div class="nav-container">
    
    <!-- Link da Logomarca redirecionando para a home -->
    <a href="/" class="nav-logo">
      <!-- Logo exibida no estado inicial (topo da página) -->
      <Image
        src={logoV1}
        alt="Logo Papa Óleo - Coleta de Óleo Usado"
        class="logo-default"
      />
      <!-- Logo exibida quando a página é rolada para baixo (scrolled) -->
      <Image
        src={logoV2}
        alt="Logo Papa Óleo - Coleta de Óleo Usado"
        class="logo-scrolled"
      />
    </a>

    <!-- Menu de navegação projetado para resoluções Desktop -->
    <ol class="nav-links-desktop">
      {
        // Itera sobre o array de links declarado no topo para criar os itens da lista dinamicamente
        navLinks.map((item) => (
          <li>
            <a href={item.href} class="nav-link">
              {item.label}
            </a>
          </li>
        ))
      }
    </ol>

    <!-- Botão de "Entrar em Contato" visível apenas no Desktop -->
    <a href="/formulario" class="btn-cta-desktop"> Entrar em Contato </a>

    <!-- 
      Botão de alternância (Toggle) para o menu Mobile (Hamburguer).
      Exibido apenas em telas menores. O script JS escuta o clique neste elemento.
    -->
    <button id="mobile-menu-btn" class="mobile-toggle" aria-label="Menu">
      <!-- Ícone SVG de Hamburguer (3 linhas), padrão quando o menu está fechado -->
      <svg
        class="menu-icon"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <path d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
      <!-- Ícone SVG de Fechar (X), inicialmente oculto pela classe .hidden -->
      <svg
        class="close-icon hidden"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <path d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <!-- 
    Container do Menu Mobile expansível.
    Este bloco é ativado e desativado (desliza ou aparece) via JS 
    quando o usuário clica no botão hambúrguer.
  -->
  <div id="mobile-menu" class="mobile-menu">
    <div class="mobile-menu-content">
      <!-- Lista de links formatada para Mobile (tamanho maior e disposta em coluna) -->
      <ol class="mobile-nav-list">
        {
          navLinks.map((item) => (
            <li>
              <a href={item.href} class="mobile-nav-link">
                {item.label}
              </a>
            </li>
          ))
        }
      </ol>
      <!-- Botão de ação (CTA) que também é inserido dentro do menu no Mobile -->
      <a href="/formulario" class="btn-cta-mobile"> Entrar em Contato </a>
    </div>
  </div>
</nav>

<!-- 
  Estilo Global (is:global):
  Este bloco afeta o HTML da página inteira.
  Aqui, ativa o "smooth scroll" global, permitindo que a navegação
  por âncoras (ex: /#o-que-fazemos) seja animada de forma suave.
-->
<style is:global>
  html {
    scroll-behavior: smooth;
  }
</style>

<!-- 
  Estilo Local (Scoped):
  Importa as classes CSS exclusivas que moldam o visual e o responsivo do cabeçalho.
-->
<style>
  @import "../styles/components-styles/header.css";
</style>

<!-- 
  Script para interatividade do Header:
  - Adiciona e remove a classe "scrolled" ao rolar a página.
  - Lógica de abrir/fechar o menu mobile, trocando o ícone e a visibilidade do contêiner.
-->
<script src="../scripts/header.js"></script>
