---
const navLinks = [
  { label: "Início", href: "/" },
  { label: "Como funciona", href: "/#o-que-fazemos" },
  { label: "Quem atendemos", href: "/#quem-atendemos" },
];
---

<nav id="main-nav" class="navbar">
  <div class="nav-container">
    <a href="/" class="nav-logo">
      <img src="/images/logo_v1.svg" alt="GiGi Energy" class="logo-default" />
      <img src="/images/logo_v2.svg" alt="GiGi Energy" class="logo-scrolled" />
    </a>

    <div class="nav-links-desktop">
      {navLinks.map((item) => (
        <a href={item.href} class="nav-link">
          {item.label}
        </a>
      ))}
    </div>

    <a href="/#contato" class="btn-cta-desktop">
      Entrar em Contato
    </a>

    <button id="mobile-menu-btn" class="mobile-toggle" aria-label="Menu">
      <svg class="menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
      <svg class="close-icon hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="mobile-menu">
    <div class="mobile-menu-content">
      {navLinks.map((item) => (
        <a href={item.href} class="mobile-nav-link">
          {item.label}
        </a>
      ))}
      <a href="/#contato" class="btn-cta-mobile">
        Entrar em Contato
      </a>
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById('main-nav');
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.querySelector('.menu-icon');
  const closeIcon = document.querySelector('.close-icon');

  let lastScrollY = window.scrollY;

  // Função centralizada para fechar o menu e destravar o scroll
  function closeMobileMenu() {
    if (mobileMenu?.classList.contains('open')) {
      mobileMenu.classList.remove('open');
      navbar?.classList.remove('menu-open');
      menuIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      document.body.style.overflow = ''; 
    }
  }

  // Fechar o menu automaticamente ao clicar num link âncora no mobile
  const mobileNavLinks = document.querySelectorAll('.mobile-nav-link, .btn-cta-mobile');
  mobileNavLinks.forEach(link => {
    link.addEventListener('click', () => {
      closeMobileMenu();
    });
  });

  window.addEventListener('scroll', () => {
    const currentScrollY = window.scrollY;
    const isMenuOpen = mobileMenu?.classList.contains('open');

    // 1. Controle visual da cor de fundo
    if (currentScrollY > 50) {
      navbar?.classList.add('scrolled');
    } else {
      navbar?.classList.remove('scrolled');
    }

    // 2. Controle de visibilidade (Rolagem para baixo vs cima)
    if (currentScrollY > lastScrollY && currentScrollY > 100 && !isMenuOpen) {
      navbar?.classList.add('hidden-nav');
    } else {
      navbar?.classList.remove('hidden-nav');
    }

    lastScrollY = currentScrollY;
  });

  function toggleMenu(e: Event) {
    e.stopPropagation(); 
    const isOpening = !mobileMenu?.classList.contains('open');
    
    if (isOpening) {
      mobileMenu?.classList.add('open');
      navbar?.classList.add('menu-open'); 
      menuIcon?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
      document.body.style.overflow = 'hidden'; 
    } else {
      closeMobileMenu();
    }
  }

  mobileBtn?.addEventListener('click', toggleMenu);

  document.addEventListener('click', (e) => {
    if (mobileMenu?.classList.contains('open') && !navbar?.contains(e.target as Node)) {
      closeMobileMenu();
    }
  });

  document.addEventListener('wheel', () => {
    if (mobileMenu?.classList.contains('open')) {
      closeMobileMenu();
    }
  }, { passive: true });

  document.addEventListener('touchmove', (e) => {
    if (mobileMenu?.classList.contains('open') && !navbar?.contains(e.target as Node)) {
      closeMobileMenu();
    }
  }, { passive: true });
</script>

<!-- REGRAS GLOBAIS DE SCROLL -->
<style is:global>
  html {
    scroll-behavior: smooth;
    /* Margem de segurança de 80px removida conforme solicitado */
  }
</style>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    transition: background-color 0.4s ease, box-shadow 0.4s ease;
    background-color: transparent;
    font-family: var(--font-sans);
  }

  .navbar.menu-open {
    border-bottom-left-radius: 1.25rem;
    border-bottom-right-radius: 1.25rem;
  }

  @media (min-width: 768px) {
    .navbar.menu-open {
      border-bottom-left-radius: 0;
      border-bottom-right-radius: 0;
    }
  }

  .navbar.hidden-nav {
    transform: translateY(-100%);
  }

  .navbar.scrolled {
    background-color: var(--brand-green);
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
  }

  .nav-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .logo-default, .logo-scrolled {
    height: 48px;
    width: auto;
    object-fit: contain;
  }

  .logo-scrolled {
    display: none;
  }

  .navbar.scrolled .logo-default {
    display: none;
  }

  .navbar.scrolled .logo-scrolled {
    display: block;
  }

  .nav-links-desktop {
    display: none;
    align-items: center;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .nav-links-desktop { display: flex; }
  }

  .nav-link {
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--charcoal);
    transition: color 0.3s;
  }

  /* Efeito de destaque apenas no hover ou no clique (:active) */
  .nav-link:hover, .nav-link:active {
    color: var(--brand-green);
  }

  .navbar.scrolled .nav-link {
    color: var(--bg-white);
  }

  .navbar.scrolled .nav-link:hover, .navbar.scrolled .nav-link:active {
    color: var(--brand-yellow);
  }

  .btn-cta-desktop {
    display: none;
    background-color: var(--brand-green);
    color: var(--bg-white);
    height: 48px; 
    padding: 0 1.5rem;
    border-radius: 9999px;
    font-weight: 700;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: background-color 0.3s, color 0.3s, transform 0.2s;
  }

  @media (min-width: 768px) {
    .btn-cta-desktop {
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
  }

  .btn-cta-desktop:hover {
    transform: scale(1.02);
  }

  .navbar.scrolled .btn-cta-desktop {
    background-color: var(--brand-yellow);
    color: var(--bg-white); 
  }

  .mobile-toggle {
    display: block;
    background: transparent;
    border: none;
    color: var(--charcoal);
    cursor: pointer;
    padding: 0.5rem;
  }

  .navbar.scrolled .mobile-toggle {
    color: var(--bg-white);
  }

  @media (min-width: 768px) {
    .mobile-toggle { display: none; }
  }

  .mobile-toggle svg {
    width: 28px;
    height: 28px;
  }

  .hidden { display: none; }

  .mobile-menu {
    display: none;
    background-color: var(--bg-white);
    border-bottom-left-radius: 1.25rem;
    border-bottom-right-radius: 1.25rem;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
  }

  .navbar.scrolled .mobile-menu {
    background-color: var(--brand-green);
    box-shadow: none; 
  }

  .mobile-menu.open {
    display: block;
  }

  .mobile-menu-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .mobile-nav-link {
    text-decoration: none;
    color: var(--charcoal);
    font-size: 1.125rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  .mobile-nav-link:hover, .mobile-nav-link:active {
    color: var(--brand-green);
  }

  .navbar.scrolled .mobile-nav-link {
    color: var(--bg-white);
  }

  .navbar.scrolled .mobile-nav-link:hover, .navbar.scrolled .mobile-nav-link:active {
    color: var(--brand-yellow);
  }

  .btn-cta-mobile {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 48px;
    background-color: var(--brand-green);
    color: var(--bg-white);
    border-radius: 9999px;
    font-weight: 700;
    text-decoration: none;
    margin-top: 0.5rem;
  }

  .navbar.scrolled .btn-cta-mobile {
    background-color: var(--brand-yellow);
    color: var(--bg-white);
  }
</style>