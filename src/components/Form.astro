---

<!-- Seção principal do formulário (Ocupa a tela inteira e define o contexto) -->
<section class="form-page-section">
  <!-- Fundo animado: Gradientes e manchas verdes/amarelas idênticas às outras seções -->
  <div class="form-background">
    <div class="bg-gradient-overlay"></div>
    <div class="bg-blob blob-green form-blob-1"></div>
    <div class="bg-blob blob-yellow form-blob-2"></div>
  </div>
  <!-- Camada de textura de "ruído" sutil sobre o fundo -->
  <div class="form-noise-wrapper noise-overlay"></div>

  <!-- Contêiner que centraliza o conteúdo e limita a largura máxima na tela -->
  <div class="form-page-container">
    <!-- Grid principal: Divide a tela em duas colunas (no Desktop) -->
    <div class="form-page-grid">
      <!-- Coluna Esquerda: Títulos, informações e lista de opções -->
      <div class="form-page-sidebar">
        <div class="sidebar-header">
          <span class="subtitle">ENTRE EM CONTATO</span>
          <h2 class="title">Fale Conosco</h2>
        </div>

        <div class="support-card">
          <h3 class="support-title">O que posso fazer aqui?</h3>
          <p class="support-text">Neste canal você pode:</p>
          <ul class="support-list">
            <li>Agendar a coleta</li>
            <li>Fazer sugestões</li>
            <li>Registrar uma reclamação</li>
            <li>Tirar dúvidas</li>
            <li>Propor parcerias</li>
          </ul>
        </div>
      </div>

      <!-- Coluna Direita: O cartão branco contendo os inputs do formulário -->
      <div class="form-page-content">
        <div class="form-card">
          <!-- Formulário com data-validate="true" (capturado pelo script form_validate.js) -->
          <form id="contact-form" data-validate="true">
            <!-- Agrupamento de inputs na mesma linha: Nome e Telefone -->
            <div class="form-row">
              <div class="form-group flex-1">
                <label for="name" class="form-label">Nome <span>*</span></label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  class="form-control"
                  placeholder="Seu nome completo"
                  required
                />
                <span class="error-text">Preencha este campo</span>
              </div>

              <div class="form-group flex-1">
                <label for="phone" class="form-label"
                  >Número <span>*</span></label
                >
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  class="form-control"
                  placeholder="(00) 00000-0000"
                  required
                />
                <span class="error-text">Telefone inválido</span>
              </div>
            </div>

            <!-- Campo de E-mail: Ocupa a linha inteira -->
            <div class="form-group">
              <label for="email" class="form-label">E-mail</label>
              <input
                type="email"
                id="email"
                name="email"
                class="form-control"
                placeholder="seu@email.com"
              />
              <span class="error-text">Formato de e-mail inválido</span>
            </div>

            <!-- Seleção de Assunto: Define se campos extras serão mostrados -->
            <div class="form-group">
              <label for="subject" class="form-label"
                >Assunto <span>*</span></label
              >
              <select id="subject" name="subject" class="form-control" required>
                <option value="" disabled selected>Selecione uma opção</option>
                <option value="agendar_coleta">Agendar coleta</option>
                <option value="duvida">Dúvida</option>
                <option value="reclamacao_sugestao"
                  >Fazer reclamação ou sugestão</option
                >
                <option value="parceria">Parceria</option>
                <option value="outro">Outro</option>
              </select>
              <span class="error-text">Selecione uma opção</span>
            </div>

            <!-- Grupo de campos CONDICIONAIS: Revelados via JavaScript APENAS se o assunto for "Agendar Coleta" -->
            <div id="agendar-fields" class="conditional-field flex-column">
              <!-- Linha: Tipo de Coleta e Quantidade de Litros -->
              <div class="form-row">
                <div class="form-group flex-1">
                  <label for="collection-type" class="form-label"
                    >Tipo de Coleta <span>*</span></label
                  >
                  <select
                    id="collection-type"
                    name="collection-type"
                    class="form-control"
                  >
                    <option value="" disabled selected
                      >Selecione o tipo de coleta</option
                    >
                    <option value="comercial">Comercial</option>
                    <option value="residencial">Residencial</option>
                    <option value="restaurante">Restaurante</option>
                    <option value="industria">Indústria</option>
                  </select>
                  <span class="error-text">Selecione uma opção</span>
                </div>

                <div class="form-group flex-1">
                  <label for="liters" class="form-label"
                    >Quantidade de litros <span>*</span></label
                  >
                  <input
                    type="number"
                    id="liters"
                    name="liters"
                    class="form-control"
                    placeholder="Ex: 50"
                    min="1"
                  />
                  <span class="error-text">Preencha este campo</span>
                </div>
              </div>

              <!-- Linha: Endereço e Número -->
              <div class="form-row address-row">
                <!-- Flex-2 faz este campo ocupar o dobro do espaço do campo de número -->
                <div class="form-group flex-2">
                  <label for="address" class="form-label"
                    >Endereço (Rua/Av, Bairro, Cidade) <span>*</span></label
                  >
                  <input
                    type="text"
                    id="address"
                    name="address"
                    class="form-control"
                    placeholder="Sua rua, bairro, cidade"
                  />
                  <span class="error-text">Preencha este campo</span>
                </div>

                <div class="form-group flex-1">
                  <label for="address-number" class="form-label"
                    >Nº <span>*</span></label
                  >
                  <input
                    type="text"
                    id="address-number"
                    name="address-number"
                    class="form-control"
                    placeholder="Número"
                  />
                  <span class="error-text">Preencha este campo</span>
                </div>
              </div>
            </div>

            <!-- Campo de Mensagem (Torna-se opcional caso o Assunto seja "Agendar coleta") -->
            <div class="form-group conditional-field" id="message-group">
              <label for="message" class="form-label" id="message-label"
                >Mensagem <span id="message-required-span">*</span></label
              >
              <textarea
                id="message"
                name="message"
                class="form-control"
                placeholder="Escreva sua mensagem aqui..."
                required></textarea>
              <span class="error-text">Preencha este campo</span>
            </div>

            <!-- Botão de Envio Principal -->
            <button type="submit" class="form-submit-btn">
              Enviar Mensagem
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Importação do arquivo de estilos específico para o Formulário */
  @import "../styles/components-styles/form.css";
</style>

<!-- Scripts responsáveis pela lógica de interação (mostrar campos ocultos) e validação -->
<script src="../scripts/form.js"></script>
<script src="../scripts/form_validate.js"></script>
