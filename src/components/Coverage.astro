---
/**
 * ==========================================
 * Coverage.astro
 * ==========================================
 * ONDE ESTÁ SENDO USADO:
 * Renderizado na página inicial (`src/pages/index.astro`), logo antes da seção de Fale Conosco.
 *
 * O QUE ELE FAZ:
 * Exibe a área de cobertura de atuação da empresa. Consiste em:
 * - Uma imagem principal de mapa dinâmico (trocado via JavaScript).
 * - Um sistema de abas (Tabs) para alternar entre "Região Metropolitana" e "Litoral Gaúcho".
 * - Cada aba altera a imagem do mapa na esquerda e exibe o cartão de informações
 *   correspondente na direita.
 * - Armazena as imagens de cada estado (selecionado) em `data-attributes` na seção
 *   para facilitar a troca via script.
 * ==========================================
 */

import mapMetroOn from "../assets/images/coverage_map_poa-selected.svg";
import mapBeachOn from "../assets/images/coverage_map_coastal-selected.svg";
import poaIcon from "../assets/images/coverage_poa_icon.svg";
import coastalIcon from "../assets/images/coverage_coastal_icon.svg";
---

<section
  class="coverage-section"
  id="cobertura"
  data-map-metro={mapMetroOn.src}
  data-map-beach={mapBeachOn.src}
>
  <div class="section-header text-center">
    <h2 class="section-title">Área de operação</h2>
    <p class="global-support-text">
      Confira nossa área de cobertura para a coleta de óleo.
    </p>
  </div>

  <div class="coverage-container">
    <div class="coverage-grid">
      <div class="map-wrapper">
        <img
          src={mapMetroOn.src}
          alt="Mapa do Rio Grande do Sul"
          class="base-map"
          id="main-map"
        />
      </div>

      <div class="content-wrapper">
        <div class="tab-buttons" role="tablist">
          <button
            class="active"
            data-target="metro"
            role="tab"
            aria-selected="true"
            id="btn-metro"
            aria-controls="metro">Região Metropolitana</button
          >
          <button
            data-target="litoral"
            role="tab"
            aria-selected="false"
            id="btn-litoral"
            aria-controls="litoral">Litoral Gaúcho</button
          >
        </div>

        <div class="tab-contents-container">
          <div
            class="tab-content active"
            id="metro"
            role="tabpanel"
            aria-labelledby="btn-metro"
          >
            <div class="tab-card">
              <div class="card-header">
                <div class="card-icon">
                  <img src={poaIcon.src} alt="" />
                </div>
                <h3>Porto Alegre e Região Metropolitana</h3>
              </div>
              <div class="card-body">
                <p>
                  Nosso serviço abrange a capital <strong
                    >Porto Alegre e as cidades do entorno</strong
                  >
                  (Canoas, Cachoeirinha, Gravataí e Alvorada).
                </p>
                <p>
                  Para municípios mais afastados, o atendimento é avaliado e
                  agendado de acordo com o volume de óleo gerado.
                </p>
                <p class="notice">Para mais informações entre em contato</p>
              </div>
            </div>
          </div>

          <div
            class="tab-content"
            id="litoral"
            role="tabpanel"
            aria-labelledby="btn-litoral"
          >
            <div class="tab-card">
              <div class="card-header">
                <div class="card-icon">
                  <img src={coastalIcon.src} alt="" />
                </div>
                <h3>Litoral Gaúcho e arredores</h3>
              </div>
              <div class="card-body">
                <p>
                  Nossa operação se estende pelas praias entre <strong
                    >Tramandaí e Capão da Canoa</strong
                  >, incluindo os municípios arredores.
                </p>
                <p>
                  Nesta região, a coleta ocorre mediante avaliação da rota e da
                  quantidade de óleo disponível.
                </p>
                <p class="notice">Para mais informações entre em contato</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @import "../styles/components-styles/coverage.css";
</style>

<script src="../scripts/coverage.js"></script>
