---
import mapMetroOn from "../assets/images/coverage_map_poa-selected.svg";
import mapBeachOn from "../assets/images/coverage_map_coastal-selected.svg";
import poaIcon from "../assets/images/coverage_poa_icon.svg";
import coastalIcon from "../assets/images/coverage_coastal_icon.svg";
---

<section
  class="coverage-section"
  id="cobertura"
  data-map-metro={mapMetroOn.src}
  data-map-beach={mapBeachOn.src}
>
  <div class="section-header text-center">
    <h2 class="section-title">Área de operação</h2>
    <p class="global-support-text">
      Confira nossa área de cobertura para a coleta de óleo.
    </p>
  </div>
  <div class="coverage-container">
    <div class="coverage-grid">
      <div class="map-wrapper">
        <img
          src={mapMetroOn.src}
          alt="Mapa do Rio Grande do Sul"
          class="base-map"
          id="main-map"
        />
      </div>

      <div class="content-wrapper">
        <div class="tab-buttons" role="tablist">
          <button class="active" data-target="metro" role="tab" aria-selected="true" id="btn-metro" aria-controls="metro"
            >Região Metropolitana</button
          >
          <button data-target="litoral" role="tab" aria-selected="false" id="btn-litoral" aria-controls="litoral">Litoral Gaúcho</button>
        </div>

        <div class="tab-contents-container">
          <div class="tab-content active" id="metro" role="tabpanel" aria-labelledby="btn-metro">
            <div class="tab-card">
              <div class="card-header">
                <div class="card-icon">
                  <img src={poaIcon.src} alt="" />
                </div>
                <h3>Porto Alegre e Região Metropolitana</h3>
              </div>
              <div class="card-body">
                <p>
                  Nosso serviço abrange a capital <strong
                    >Porto Alegre e as cidades do entorno</strong
                  >
                  (Canoas, Cachoeirinha, Gravataí e Alvorada).
                </p>
                <p>
                  Para municípios mais afastados, o atendimento é avaliado e
                  agendado de acordo com o volume de óleo gerado.
                </p>
                <p class="notice">Para mais informações entre em contato</p>
              </div>
            </div>
          </div>

          <div class="tab-content" id="litoral" role="tabpanel" aria-labelledby="btn-litoral">
            <div class="tab-card">
              <div class="card-header">
                <div class="card-icon">
                  <img src={coastalIcon.src} alt="" />
                </div>
                <h3>Litoral Gaúcho e arredores</h3>
              </div>
              <div class="card-body">
                <p>
                  Nossa operação se estende pelas praias entre <strong
                    >Tramandaí e Capão da Canoa</strong
                  >, incluindo os municípios arredores.
                </p>
                <p>
                  Nesta região, a coleta ocorre mediante avaliação da rota e da
                  quantidade de óleo disponível.
                </p>
                <p class="notice">Para mais informações entre em contato</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .coverage-section {
    padding: 4rem 1.5rem;
    background-color: var(--bg-white);
    position: relative;
    overflow: hidden;
  }

  .text-center {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 900;
    color: var(--brand-gray, #555555);
    line-height: 1.2;
  }

  .coverage-container {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .coverage-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
  }

  @media (min-width: 992px) {
    .coverage-section {
      min-height: 100svh;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .coverage-grid {
      grid-template-columns: 1.2fr 1fr;
      gap: 2rem;
    }
  }

  .map-wrapper {
    position: relative;
    margin-right: auto;
    width: 100%;
  }

  .base-map {
    width: 100%;
    height: auto;
    max-height: 65vh;
    object-fit: contain;
    display: block;
    filter: drop-shadow(0 15px 20px rgba(0, 0, 0, 0.05));
  }

  .content-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-self: start;
    margin-top: 0;
    justify-content: center;
  }

  .global-support-text {
    font-size: 1.125rem;
    color: var(--brand-gray, #555555);
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }

  .tab-buttons {
    display: flex;
    gap: 1rem;
    border-bottom: 2px solid #e5e7eb;
    margin-bottom: 1rem;
  }

  .tab-buttons button {
    background: none;
    border: none;
    padding: 0.75rem 1rem;
    font-size: 1rem;
    font-weight: 700;
    font-family: var(--font-sans, system-ui, sans-serif);
    color: #6b7280;
    cursor: pointer;
    position: relative;
    transition: color 0.3s ease;
  }

  .tab-buttons button::after {
    content: "";
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 100%;
    height: 2px;
    background-color: var(--brand-green, #64b445);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.3s ease;
  }

  .tab-buttons button:hover {
    color: var(--brand-gray, #121212);
  }

  .tab-buttons button.active {
    color: var(--brand-green, #64b445);
  }

  .tab-buttons button.active::after {
    transform: scaleX(1);
  }

  .tab-contents-container {
    min-height: 180px;
  }

  .tab-content {
    display: none;
    animation: fadeIn 0.4s ease forwards;
  }

  .tab-content.active {
    display: block;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(5px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .tab-card {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 1.5rem;
    background-color: #ffffff;
    border-radius: 1rem;
    border: 1px solid #f3f4f6;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .card-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .card-icon img {
    width: 3.5rem;
    height: 3.5rem;
    display: block;
  }

  .card-header h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--charcoal, #121212);
    margin: 0;
  }

  .card-body p {
    font-size: 1rem;
    color: #4b5563;
    line-height: 1.5;
    margin-bottom: 1rem;
  }

  .card-body .notice {
    display: inline-block;
    background-color: rgba(251, 179, 66, 0.15);
    color: #b47000;
    font-size: 0.875rem;
    font-weight: 600;
    padding: 0.35rem 0.75rem;
    border-radius: 9999px;
    margin-bottom: 0.75rem;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const section = document.querySelector(".coverage-section");
    const buttons = document.querySelectorAll(".tab-buttons button");
    const contents = document.querySelectorAll(".tab-content");

    if (!section) return;

    const paths = {
      mapMetro: section.getAttribute("data-map-metro") || "",
      mapBeach: section.getAttribute("data-map-beach") || "",
    };

    const mainMap = document.getElementById("main-map");

    const initialActiveBtn = document.querySelector(
      ".tab-buttons button.active",
    );
    if (mainMap && initialActiveBtn) {
      const initialTarget = initialActiveBtn.getAttribute("data-target");
      if (initialTarget === "metro") {
        mainMap.setAttribute("src", paths.mapMetro);
      } else if (initialTarget === "litoral") {
        mainMap.setAttribute("src", paths.mapBeach);
      }
    }

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        buttons.forEach((btn) => {
          btn.classList.remove("active");
          btn.setAttribute("aria-selected", "false");
        });
        contents.forEach((content) => content.classList.remove("active"));

        button.classList.add("active");
        button.setAttribute("aria-selected", "true");

        const targetId = button.getAttribute("data-target");
        if (targetId) {
          const targetElement = document.getElementById(targetId);
          if (targetElement) {
            targetElement.classList.add("active");
          }

          if (mainMap) {
            if (targetId === "metro") {
              mainMap.setAttribute("src", paths.mapMetro);
            } else if (targetId === "litoral") {
              mainMap.setAttribute("src", paths.mapBeach);
            }
          }
        }
      });
    });
  });
</script>
