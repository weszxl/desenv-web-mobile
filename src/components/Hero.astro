---
/**
 * Componente: Hero.astro
 *
 * O que faz:
 * Este componente representa a seção principal (Hero Section) da página de entrada.
 * Ele engloba a mensagem principal do site (título de impacto), o subtítulo
 * com apelo comercial/ambiental, um botão de chamada para ação (agendar coleta),
 * links rápidos para o WhatsApp e a ilustração de destaque (hero image).
 *
 * Onde é usado:
 * Normalmente é o primeiro bloco visual visível (above the fold)
 * na página principal (ex: src/pages/index.astro), logo abaixo do Header.
 */

// Importações e configurações iniciais do Astro
import { Image } from "astro:assets"; // O componente Image otimiza imagens automaticamente no build
import heroImg from "../assets/images/2_hero.png"; // Ilustração principal da seção Hero
---

<section id="inicio" class="hero-section noise-overlay">
  <!-- Efeitos visuais de background (degradê e manchas coloridas animadas) -->
  <div class="bg-gradient-overlay"></div>
  <div class="bg-blob blob-green hero-blob-1"></div>
  <div class="bg-blob blob-yellow hero-blob-2"></div>

  <div class="hero-container">
    <div class="hero-main-content">
      <div class="hero-text">
        <h1 class="hero-title">
          <span class="block text-brand-green">NÓS COLETAMOS</span>
          <span class="block text-brand-gray"
            >SEU <span class="text-brand-yellow">ÓLEO</span> DE COZINHA</span
          >
        </h1>

        <p class="hero-subtitle">
          Facilite a sua rotina. Agende a retirada para o seu restaurante,
          condomínio ou casa. Ajude o meio ambiente.
        </p>
      </div>

      <div class="hero-image-wrapper">
        <div class="image-glow"></div>
        <!-- Elemento visual de desfoque/iluminação atrás da imagem -->

        <!-- 
          Utilização do componente nativo <Image> do Astro para conversão e otimização de imagem.
          A propriedade fetchpriority="high" prioriza o download dessa imagem para 
          melhorar as métricas de performance do site (Core Web Vitals - LCP).
        -->
        <Image
          src={heroImg}
          alt="Ilustração - Coleta de óleo de cozinha no Rio Grande do Sul"
          class="hero-image"
          fetchpriority="high"
        />
      </div>
    </div>

    <div class="hero-footer">
      <a
        href={`https://wa.me/${import.meta.env.PUBLIC_WHATSAPP_NUMBER}?text=${encodeURIComponent("Olá! Gostaria de agendar uma coleta de óleo.")}`}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-primary"
      >
        Agendar Coleta
      </a>

      <p class="contact-info">
        Mais informações? <a
          href={`https://wa.me/${import.meta.env.PUBLIC_WHATSAPP_NUMBER}?text=${encodeURIComponent("Olá! Poderia me dar mais informações.")}`}
          target="_blank"
          rel="noopener noreferrer">Fale conosco</a
        >
      </p>
    </div>
  </div>
</section>

<style>
  @import "../styles/components-styles/hero.css";
</style>
